            "name": "PerOperationGroup_ApiOperationAggregation"
          },
          {
            "type": 12,
            "content": {
              "version": "NotebookGroup/1.0",
              "groupType": "editable",
              "title": "Details for '{SelectedOperationName}' filtered on result code '{SelectedResultCode}' in time range '{TimeRange:label}'",
              "items": [
                {
                  "type": 11,
                  "content": {
                    "version": "LinkItem/1.0",
                    "style": "tabs",
                    "links": [
                      {
                        "id": "8f136f1f-98e5-4691-a40d-ab59e94e426f",
