                  "content": {
                    "version": "KqlItem/1.0",
                    "query": "let subscriptionFilter = dynamic([{ApimSubscription}]);\r\nlet operationNameFilter = '{SelectedOperationName}';\r\nlet resultCodeFilter = '{SelectedResultCode}';\r\n\r\nrequests\r\n| where customDimensions[\"Service Type\"] == \"API Management\"\r\n| where customDimensions[\"Service ID\"] == \"{ApiManagement:name}\"\r\n| extend subscription = tostring(customDimensions[\"Subscription Name\"])\r\n| where array_length(subscriptionFilter) == 0 or subscription in (subscriptionFilter)\r\n| where operation_Name == operationNameFilter\r\n| where isempty(resultCodeFilter) or resultCode == resultCodeFilter\r\n| extend requestSize = toint(customMeasurements[\"Request Size\"])\r\n| union (\r\n    range x from 1 to 1 step 1\r\n    | mv-expand timestamp=range({TimeRange:start}, {TimeRange:end}, {TimeGranularity:value}) to typeof(datetime)\r\n    | extend requestSize=toint(0)\r\n    )\r\n| summarize avg = avg(requestSize), (median, p80, p95, p99) = percentiles(requestSize, 50, 80, 95, 99) by bin(timestamp, {TimeGranularity:value})",
