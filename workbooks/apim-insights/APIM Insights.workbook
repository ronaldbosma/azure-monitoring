    {
      "type": 9,
      "content": {
        "version": "KqlParameterItem/1.0",
        "crossComponentResources": [
          "{ApplicationInsights}"
        ],
        "parameters": [
          {
            "id": "147574af-4269-44a7-a327-23adeb5167b3",
            "version": "KqlParameterItem/1.0",
            "name": "TimeGranularity",
            "label": "Time granularity of graphs",
            "type": 2,
            "typeSettings": {
              "additionalResourceOptions": []
            },
            "jsonData": "[\r\n    { \"value\": \"1m\", \"label\": \"1 minute\"},\r\n    { \"value\": \"5m\", \"label\": \"5 minutes\"},\r\n    { \"value\": \"15m\", \"label\": \"15 minutes\"},\r\n    { \"value\": \"1h\", \"label\": \"1 hour\"},\r\n    { \"value\": \"4h\", \"label\": \"4 hours\"},\r\n    { \"value\": \"12h\", \"label\": \"12 hours\"},\r\n    { \"value\": \"1d\", \"label\": \"1 day\"}\r\n]",
            "timeContext": {
              "durationMs": 86400000
            },
            "value": "1h"
          },
          {
            "id": "33efc72d-00fa-4f03-b3e3-150d0ce96b15",
            "version": "KqlParameterItem/1.0",
            "name": "ApimSubscription",
            "label": "Subscription",
            "type": 2,
            "multiSelect": true,
            "quote": "'",
            "delimiter": ",",
            "query": "requests\r\n| where customDimensions[\"Service Type\"] == \"API Management\"\r\n| where customDimensions[\"Service ID\"] == \"{ApiManagement:name}\"\r\n| extend subscription = tostring(customDimensions[\"Subscription Name\"])\r\n| distinct subscription\r\n| sort by subscription asc",
            "crossComponentResources": [
              "{ApplicationInsights}"
            ],
            "typeSettings": {
              "additionalResourceOptions": [],
              "showDefault": false
            },
            "timeContext": {
              "durationMs": 0
            },
            "timeContextFromParameter": "TimeRange",
            "queryType": 0,
            "resourceType": "microsoft.insights/components",
            "value": []
          },
          {
            "id": "0ca495c1-2758-425e-b830-d95ed7a1f718",
            "version": "KqlParameterItem/1.0",
            "name": "API",
            "type": 2,
            "multiSelect": true,
            "quote": "'",
            "delimiter": ",",
            "query": "let subscriptionFilter = dynamic([{ApimSubscription}]);\r\n\r\nrequests\r\n| where customDimensions[\"Service Type\"] == \"API Management\"\r\n| where customDimensions[\"Service ID\"] == \"{ApiManagement:name}\"\r\n| extend \r\n    subscription = tostring(customDimensions[\"Subscription Name\"]),\r\n    api = tostring(customDimensions[\"API Name\"])\r\n| where array_length(subscriptionFilter) == 0 or subscription in (subscriptionFilter)\r\n| distinct api\r\n| sort by api asc",
            "crossComponentResources": [
              "{ApplicationInsights}"
            ],
            "typeSettings": {
              "additionalResourceOptions": [],
              "showDefault": false
            },
            "timeContext": {
              "durationMs": 0
            },
            "timeContextFromParameter": "TimeRange",
            "queryType": 0,
            "resourceType": "microsoft.insights/components",
            "value": []
          }
        ],
        "style": "pills",
        "queryType": 0,
        "resourceType": "microsoft.insights/components"
      },
      "name": "ApimRequestParameters"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Overall Insights",
        "expandable": true,
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "let subscriptionFilter = dynamic([{ApimSubscription}]);\r\nlet apiFilter = dynamic([{API}]);\r\n\r\nrequests\r\n| where customDimensions[\"Service Type\"] == \"API Management\"\r\n| where customDimensions[\"Service ID\"] == \"{ApiManagement:name}\"\r\n| extend \r\n    subscription = tostring(customDimensions[\"Subscription Name\"]),\r\n    api = tostring(customDimensions[\"API Name\"])\r\n| where array_length(subscriptionFilter) == 0 or subscription in (subscriptionFilter)\r\n| where array_length(apiFilter) == 0 or api in (apiFilter)\r\n| make-series numberOfRequests=count() default=0 on timestamp from todatetime(\"{TimeRange:startISO}\") to todatetime(\"{TimeRange:endISO}\") step {TimeGranularity:value} by success",
              "size": 1,
              "showAnalytics": true,
              "title": "Number of requests (time range: {TimeRange:label})",
              "timeContextFromParameter": "TimeRange",
              "timeBrushParameterName": "TimeRange",
              "timeBrushExportOnlyWhenBrushed": true,
              "showRefreshButton": true,
              "showExportToExcel": true,
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "{ApplicationInsights}"
              ],
              "visualization": "barchart",
              "chartSettings": {
                "seriesLabelSettings": [
                  {
                    "seriesName": "True",
                    "label": "Success",
                    "color": "green"
                  },
                  {
                    "seriesName": "False",
                    "label": "Failure",
                    "color": "redBright"
                  }
                ]
              }
            },
            "name": "OverallGroup_NumberOfRequests"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "let subscriptionFilter = dynamic([{ApimSubscription}]);\r\nlet apiFilter = dynamic([{API}]);\r\n\r\nrequests\r\n| where customDimensions[\"Service Type\"] == \"API Management\"\r\n| where customDimensions[\"Service ID\"] == \"{ApiManagement:name}\"\r\n| where success == false\r\n| extend \r\n    subscription = tostring(customDimensions[\"Subscription Name\"]),\r\n    api = tostring(customDimensions[\"API Name\"])\r\n| where array_length(subscriptionFilter) == 0 or subscription in (subscriptionFilter)\r\n| where array_length(apiFilter) == 0 or api in (apiFilter)\r\n| make-series numberOfRequests=count() default=0 on timestamp from todatetime(\"{TimeRange:startISO}\") to todatetime(\"{TimeRange:endISO}\") step {TimeGranularity:value}",
              "size": 1,
              "showAnalytics": true,
              "title": "Number of failed requests (time range: {TimeRange:label})",
              "timeContextFromParameter": "TimeRange",
              "timeBrushParameterName": "TimeRange",
              "timeBrushExportOnlyWhenBrushed": true,
              "showRefreshButton": true,
              "showExportToExcel": true,
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "{ApplicationInsights}"
              ],
              "visualization": "barchart",
              "chartSettings": {
                "seriesLabelSettings": [
                  {
                    "seriesName": "numberOfRequests",
                    "color": "redBright"
                  }
                ]
              }
            },
            "name": "OverallGroup_NumberOfFailedRequests"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "let subscriptionFilter = dynamic([{ApimSubscription}]);\r\nlet apiFilter = dynamic([{API}]);\r\n\r\nrequests\r\n| where customDimensions[\"Service Type\"] == \"API Management\"\r\n| where customDimensions[\"Service ID\"] == \"{ApiManagement:name}\"\r\n| extend \r\n    subscription = tostring(customDimensions[\"Subscription Name\"]),\r\n    api = tostring(customDimensions[\"API Name\"])\r\n| where array_length(subscriptionFilter) == 0 or subscription in (subscriptionFilter)\r\n| where array_length(apiFilter) == 0 or api in (apiFilter)\r\n| union (\r\n    range x from 1 to 1 step 1\r\n    | mv-expand timestamp=range({TimeRange:start}, {TimeRange:end}, {TimeGranularity:value}) to typeof(datetime)\r\n    | extend duration=0.0\r\n    )\r\n| summarize avg = avg(duration), (median, p80, p95) = percentiles(duration, 50, 80, 95) by bin(timestamp, {TimeGranularity:value})",
              "size": 1,
              "aggregation": 3,
              "showAnalytics": true,
              "title": "Request duration (time range: {TimeRange:label})",
              "timeContextFromParameter": "TimeRange",
              "timeBrushParameterName": "TimeRange",
              "timeBrushExportOnlyWhenBrushed": true,
              "showRefreshButton": true,
              "showExportToExcel": true,
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "{ApplicationInsights}"
              ],
              "visualization": "timechart"
            },
            "name": "OverallGroup_RequestDuration"
          }
        ]
      },
      "name": "OverallGroup"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Insights Per Operation",
        "expandable": true,
        "items": [
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "let subscriptionFilter = dynamic([{ApimSubscription}]);\r\nlet apiFilter = dynamic([{API}]);\r\n\r\nlet filteredRequests = requests\r\n| where customDimensions[\"Service Type\"] == \"API Management\"\r\n| where customDimensions[\"Service ID\"] == \"{ApiManagement:name}\"\r\n| extend \r\n    subscription = tostring(customDimensions[\"Subscription Name\"]),\r\n    api = tostring(customDimensions[\"API Name\"])\r\n| where array_length(subscriptionFilter) == 0 or subscription in (subscriptionFilter)\r\n| where array_length(apiFilter) == 0 or api in (apiFilter)\r\n| extend \r\n    operation = tostring(customDimensions[\"Operation Name\"]),\r\n    requestSize = toint(customMeasurements[\"Request Size\"]),\r\n    responseSize = toint(customMeasurements[\"Response Size\"])\r\n;\r\n\r\nlet operations = filteredRequests\r\n| summarize \r\n        numberOfRequests = count(),\r\n        numberOfFailures = countif(success == false),\r\n        failRatio = round(100.0 * countif(success == false) / count(), 2),\r\n        avgDuration = avg(duration),\r\n        (medianDuration, p80Duration, p95Duration, p99Duration) = percentiles(duration, 50, 80, 95, 99),\r\n        avgRequestSize = avg(requestSize),\r\n        sumRequestSize = sum(requestSize),\r\n        avgResponseSize = avg(responseSize),\r\n        sumResponseSize = sum(responseSize)\r\n    by rowName = api, rowId = operation_Name, parentRowId = '', operation, operation_Name, resultCode = ''\r\n| sort by numberOfRequests desc\r\n;\r\n\r\nlet operationsPerResultCode = filteredRequests\r\n| summarize \r\n        numberOfRequests = count(),\r\n        numberOfFailures = countif(success == false),\r\n        failRatio = round(100.0 * countif(success == false) / count(), 2),\r\n        avgDuration = avg(duration),\r\n        (medianDuration, p80Duration, p95Duration, p99Duration) = percentiles(duration, 50, 80, 95, 99),\r\n        avgRequestSize = avg(requestSize),\r\n        sumRequestSize = sum(requestSize),\r\n        avgResponseSize = avg(responseSize),\r\n        sumResponseSize = sum(responseSize)\r\n    by rowName = resultCode, rowId = strcat(operation_Name, ': ', resultCode), parentRowId = operation_Name, operation, operation_Name, resultCode\r\n| sort by resultCode asc\r\n;\r\n\r\nunion operations, operationsPerResultCode\r\n",
              "size": 0,
              "showAnalytics": true,
              "title": "Aggregation per API operation (time range: {TimeRange:label})",
              "timeContextFromParameter": "TimeRange",
              "showRefreshButton": true,
              "exportedParameters": [
                {
                  "fieldName": "operation_Name",
                  "parameterName": "SelectedOperationName",
                  "parameterType": 1
                },
                {
                  "fieldName": "resultCode",
                  "parameterName": "SelectedResultCode",
                  "parameterType": 1
                }
              ],
              "showExportToExcel": true,
              "queryType": 0,
              "resourceType": "microsoft.insights/components",
              "crossComponentResources": [
                "{ApplicationInsights}"
              ],
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "rowName",
                    "formatter": 0,
                    "formatOptions": {
                      "customColumnWidthSetting": "25ch"
                    }
                  },
                  {
                    "columnMatch": "rowId",
                    "formatter": 5
                  },
                  {
                    "columnMatch": "parentRowId",
                    "formatter": 5
                  },
                  {
                    "columnMatch": "operation",
                    "formatter": 0,
                    "formatOptions": {
                      "customColumnWidthSetting": "25ch"
                    }
                  },
                  {
                    "columnMatch": "operation_Name",
                    "formatter": 5
                  },
                  {
                    "columnMatch": "resultCode",
                    "formatter": 5
                  },
                  {
                    "columnMatch": "numberOfRequests",
                    "formatter": 0,
                    "formatOptions": {
                      "customColumnWidthSetting": "22ch"
                    },
                    "numberFormat": {
                      "unit": 0,
                      "options": {
                        "style": "decimal"
                      }
                    }
                  },
                  {
                    "columnMatch": "numberOfFailures",
                    "formatter": 0,
                    "formatOptions": {
                      "customColumnWidthSetting": "21ch"
                    },
                    "numberFormat": {
                      "unit": 0,
